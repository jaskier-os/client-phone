<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gbx_bg"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar -->
        <LinearLayout
            android:id="@+id/rcTopBar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/gbx_bg0_hard"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/rcBtnBack"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/rcTitle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:textColor="@color/gbx_fg"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/rcContextPct"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingEnd="8dp"
                android:textColor="@color/gbx_gray"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:visibility="gone" />

            <View
                android:id="@+id/rcStatusDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/rcModeSelector"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:gravity="center"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="12dp"
                android:textColor="@color/gbx_aqua"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="@drawable/bg_mode_chip"
                android:clickable="true"
                android:focusable="true"
                android:text="Ask" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/gbx_bg2" />

        <!-- Messages list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rcMessageList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/gbx_bg"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <!-- Thinking indicator -->
        <TextView
            android:id="@+id/rcThinkingView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:padding="8dp"
            android:textStyle="italic"
            android:textColor="@color/gbx_gray"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:text="Thinking..." />

        <!-- Session ended banner -->
        <TextView
            android:id="@+id/rcEndedBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/gbx_bg0_hard"
            android:gravity="center"
            android:padding="8dp"
            android:text="Session ended"
            android:textColor="@color/gbx_gray"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

        <!-- Action buttons (approve/reject + overflow) - shown above input when permission pending -->
        <GridLayout
            android:id="@+id/rcActionButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:background="@color/gbx_bg0_hard"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <!-- Input bar -->
        <LinearLayout
            android:id="@+id/rcInputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/gbx_bg0_hard"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <EditText
                android:id="@+id/rcInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_input_pill"
                android:textColor="@color/gbx_fg"
                android:textColorHint="@color/gbx_gray"
                android:hint="Send a message..."
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxLines="4"
                android:inputType="textMultiLine" />

            <ImageView
                android:id="@+id/rcStopButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:scaleType="centerInside"
                android:background="@drawable/bg_stop_button"
                android:clickable="true"
                android:focusable="true"
                android:tint="@android:color/white"
                android:visibility="gone" />

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp">

                <com.repository.listener.ui.views.VoiceRecordButton
                    android:id="@+id/rcMicButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_mic"
                    android:scaleType="centerInside"
                    android:background="@drawable/bg_mic_button"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/rcSendButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_send"
                    android:scaleType="centerInside"
                    android:background="@drawable/bg_send_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Scroll-to-bottom button (shown when user scrolls up) -->
    <ImageView
        android:id="@+id/rcScrollToBottom"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="76dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_downward"
        android:scaleType="centerInside"
        android:background="@drawable/bg_send_button"
        android:tint="@android:color/white"
        android:clickable="true"
        android:focusable="true"
        android:elevation="4dp"
        android:visibility="gone" />

    <!-- Recording overlay (covers input bar during recording) -->
    <com.repository.listener.ui.views.RecordingOverlay
        android:id="@+id/rcRecordingOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:visibility="gone" />

    <!-- History loading overlay (visible while transcript is being fetched) -->
    <LinearLayout
        android:id="@+id/rcLoadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/rcLoadingSpinner"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/gbx_aqua" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Loading conversation..."
            android:textColor="@color/gbx_gray"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </LinearLayout>
</FrameLayout>
