<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gbx_bg"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: normal mode -->
        <FrameLayout
            android:id="@+id/topBarNormal"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/gbx_bg0_hard"
            android:visibility="visible">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/titleText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="56dp"
                android:paddingEnd="56dp"
                android:textColor="@color/gbx_fg"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/btnPin"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:padding="12dp"
                android:src="@drawable/ic_star_outline"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="bottom"
                android:background="@color/gbx_bg2" />
        </FrameLayout>

        <!-- Top bar: selection mode -->
        <FrameLayout
            android:id="@+id/topBarSelection"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/gbx_bg2"
            android:visibility="gone">

            <TextView
                android:id="@+id/selectionCount"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingStart="16dp"
                android:textColor="@color/gbx_fg"
                android:textSize="14sp"
                android:fontFamily="monospace" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCopySelection"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="Copy"
                    android:textColor="@color/gbx_green"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/btnCloseSelection"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:text="X"
                    android:textColor="@color/gbx_fg"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </FrameLayout>

        <!-- Messages list -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/messagesRecycler"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/gbx_bg"
                android:clipToPadding="false"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp" />

            <!-- Scroll to bottom button -->
            <ImageView
                android:id="@+id/btnScrollToBottom"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:src="@drawable/ic_arrow_downward"
                android:scaleType="centerInside"
                android:padding="8dp"
                android:background="@drawable/bg_scroll_to_bottom"
                android:elevation="4dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- Input bar -->
        <LinearLayout
            android:id="@+id/inputBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/gbx_bg0_hard"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/btnAttach"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_attach"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_input_pill"
                android:textColor="@color/gbx_fg"
                android:textColorHint="@color/gbx_gray"
                android:hint="Message..."
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxLines="8"
                android:inputType="textMultiLine" />

            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp">

                <com.repository.listener.ui.views.VoiceRecordButton
                    android:id="@+id/btnMic"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_mic"
                    android:scaleType="centerInside"
                    android:background="@drawable/bg_mic_button"
                    android:visibility="visible" />

                <ImageView
                    android:id="@+id/btnSend"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_send"
                    android:scaleType="centerInside"
                    android:background="@drawable/bg_send_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Recording overlay (covers input bar during recording) -->
    <com.repository.listener.ui.views.RecordingOverlay
        android:id="@+id/recordingOverlay"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:visibility="gone" />
</FrameLayout>
