<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTwoWayBack"
        style="@style/Widget.Material3.Button.IconButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:contentDescription="Stop two-way translation"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconSize="24dp"
        app:iconTint="#FF9800"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <TextView
        android:id="@+id/txtTwoWayLangs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:textColor="#FF9800"
        android:textSize="16sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="RU -> TR" />

    <ScrollView
        android:id="@+id/twoWayScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:fadingEdge="vertical"
        android:fadingEdgeLength="40dp"
        app:layout_constraintTop_toBottomOf="@id/txtTwoWayLangs"
        app:layout_constraintBottom_toTopOf="@id/btnTwoWayBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/twoWayChunks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="bottom" />

    </ScrollView>

    <!-- Spectrogram and SPEAK label removed. Inward mic audio now comes
         from glasses ch0, phone mic is not used in two-way mode. -->

</androidx.constraintlayout.widget.ConstraintLayout>
