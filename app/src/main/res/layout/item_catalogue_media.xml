<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="2dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imgThumbnail"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:scaleType="centerCrop"
        android:background="@color/gbx_bg2"
        android:contentDescription="Thumbnail"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.RoundedCorner12" />

    <ImageView
        android:id="@+id/imgPlayOverlay"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="center"
        android:src="@android:drawable/ic_media_play"
        android:visibility="gone"
        android:alpha="0.85"
        android:contentDescription="Video" />

    <View
        android:id="@+id/selectionOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_gallery_tile_selection"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/imgCheckbox"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_circle_outline"
        android:contentDescription="Select"
        android:visibility="gone" />

</FrameLayout>
