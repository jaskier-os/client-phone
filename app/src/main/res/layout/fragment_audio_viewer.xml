<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gbx_bg">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gbx_bg0_hard"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="@color/gbx_orange"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/txtViewerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textSize="14sp"
            android:textColor="@color/gbx_fg"
            android:maxLines="1"
            android:ellipsize="end" />

        <ImageButton
            android:id="@+id/btnRename"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            app:tint="@color/gbx_orange"
            android:contentDescription="Rename" />

        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            app:tint="@color/gbx_orange"
            android:contentDescription="Share" />

        <ImageButton
            android:id="@+id/btnViewerPin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_star_outline"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside"
            app:tint="@color/gbx_orange"
            android:contentDescription="Pin" />

    </LinearLayout>

    <!-- Segment list (timestamps + transcriptions, clickable) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/segmentList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:clipToPadding="false" />

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gbx_bg2" />

    <!-- Current segment transcription (smaller area) -->
    <LinearLayout
        android:id="@+id/transcriptionArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtInlineTranscription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textSize="13sp"
            android:textColor="@color/gbx_fg"
            android:fontFamily="monospace"
            android:maxLines="3"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTranscribe"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="16dp"
            android:text="Transcribe"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Zoomed waveform (+-15s around tap point, 2x height of main) -->
    <com.repository.listener.ui.views.SpectrogramView
        android:id="@+id/zoomSpectrogramView"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone" />

    <!-- Spectrogram view - compact, 90% width centered -->
    <com.repository.listener.ui.views.SpectrogramView
        android:id="@+id/spectrogramView"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp" />

    <!-- Time bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gbx_bg0_hard"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/txtCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="12sp"
            android:textColor="@color/gbx_gray"
            android:fontFamily="monospace" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/txtTotalTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textSize="12sp"
            android:textColor="@color/gbx_gray"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Navigation bar - icon-only buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/gbx_bg0_hard"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp"
        android:paddingTop="4dp"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrev10s"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_replay_10"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevVoice"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_skip_previous"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlay"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="@color/gbx_green"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_play"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="28dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Material3.Button"
            app:cornerSize="50%" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextVoice"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_skip_next"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNext10s"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:minWidth="0dp"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:icon="@drawable/ic_forward_10"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="22dp" />

    </LinearLayout>

</LinearLayout>
