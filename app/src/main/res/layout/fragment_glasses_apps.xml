<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- App Tile Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:layout_marginBottom="8dp">

                <!-- Record Video Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileRecordVideo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_videocam"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Record Video"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Record AR Screen Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileRecordArScreen"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_videocam"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AR Record"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Translation Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileTranslation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_translate"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Translation"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Teleprompter Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileTeleprompter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_teleprompter"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Teleprompter"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Audio Recordings Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileAudioRecordings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_audio_recording"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audio Recordings"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Mouse Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileMouse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_mouse"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mouse"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                        <TextView
                            android:id="@+id/txtMouseStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/gbx_fg"
                            android:alpha="0.6"
                            android:gravity="center"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileLoneMode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_lone_wolf"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lone mode"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Copilot Tile -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/tileCopilot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="@color/gbx_bg1"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center_horizontal"
                        android:paddingTop="24dp"
                        android:paddingBottom="20dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">
                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_tile_icon"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_copilot"
                                app:tint="@color/gbx_orange" />
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Copilot"
                            android:textSize="13sp"
                            android:textColor="@color/gbx_fg"
                            android:gravity="center" />
                        <TextView
                            android:id="@+id/txtCopilotStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="10sp"
                            android:textColor="@color/gbx_fg"
                            android:alpha="0.6"
                            android:gravity="center"
                            android:layout_marginTop="2dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Recording Status Panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/recordingStatusSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gbx_bg1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/imgRecordingDot"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_fiber_manual_record"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:id="@+id/txtRecordingStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Recording..."
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtRecordingTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0s"
                            android:textSize="14sp"
                            android:textColor="@color/gbx_gray" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopRecording"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Stop Recording"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recording Result -->
            <TextView
                android:id="@+id/txtRecordingResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="@color/gbx_gray"
                android:visibility="gone" />

            <!-- Translation Status Panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/translationStatusSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gbx_bg1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtTranslationStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Translating..."
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSwitchAudioSource"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Switch to System Audio"
                        app:icon="@drawable/ic_swap_horiz"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTwoWayTranslation"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Enable Two-Way"
                        app:icon="@drawable/ic_swap_horiz"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStopTranslation"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Stop Translation"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="20dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Translation Result -->
            <TextView
                android:id="@+id/txtTranslationResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="@color/gbx_gray"
                android:visibility="gone" />

            <!-- Teleprompter Control Panel -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/teleprompterControlSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/gbx_bg1"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/txtTeleprompterStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Teleprompter running"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/progressTeleprompter"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="100"
                        android:progress="0"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Scroll buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTeleprompterScrollBack"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Scroll Up"
                            app:icon="@drawable/ic_arrow_upward"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTeleprompterScrollFwd"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Scroll Down"
                            app:icon="@drawable/ic_arrow_downward"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                    </LinearLayout>

                    <!-- Pause/Stop buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTeleprompterPause"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Pause"
                            app:icon="@drawable/ic_pause"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTeleprompterStop"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Stop"
                            app:icon="@drawable/ic_stop"
                            app:iconGravity="textStart"
                            app:iconSize="20dp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Teleprompter Result -->
            <TextView
                android:id="@+id/txtTeleprompterResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="@color/gbx_gray"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

    <!-- Translation loading overlay -->
    <FrameLayout
        android:id="@+id/translationLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        android:elevation="10dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">
            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                style="?android:attr/progressBarStyleLarge" />
            <TextView
                android:id="@+id/txtTranslationLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Starting translation..."
                android:textColor="@android:color/white"
                android:textSize="16sp" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
