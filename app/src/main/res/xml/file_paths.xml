<?xml version="1.0" encoding="utf-8"?>
<paths>
    <cache-path name="logs" path="logs/" />
    <files-path name="recordings" path="audio_recordings/" />
    <cache-path name="shared" path="shared_audio/" />
    <cache-path name="pdfs" path="pdfs/" />
    <!-- Glasses-synced files live under the app's external Pictures dir.
