<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="8dp">

    <!-- Transit type icon -->
    <ImageView
        android:id="@+id/sectionTypeIcon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:scaleType="centerInside"
        android:importantForAccessibility="no" />

    <!-- Section info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/sectionTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/nav_fg"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/sectionDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/nav_gray"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <!-- Equivalent line-number chips (34, 34G, 34AS...) populated at bind time -->
        <LinearLayout
            android:id="@+id/sectionLineChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Step duration -->
    <TextView
        android:id="@+id/sectionDuration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/nav_gray"
        android:textSize="12sp" />

</LinearLayout>
