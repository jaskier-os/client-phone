<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:minHeight="40dp">

    <!-- Timeline gutter -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <View
            android:id="@+id/timelineTopLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:id="@+id/timelineDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_timeline_dot" />

        <View
            android:id="@+id/timelineBottomLine"
            android:layout_width="2dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingVertical="8dp"
        android:paddingStart="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/timelineCircleBadge"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:background="@drawable/bg_circle_badge"
                android:gravity="center"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/nav_bg"
                android:layout_marginEnd="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/timelinePrimaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/nav_fg"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/timelineBadgeRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/timelineModeIcon"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:scaleType="centerInside"
                android:importantForAccessibility="no" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="4dp">

                <TextView
                    android:id="@+id/timelineBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/nav_gray" />

                <TextView
                    android:id="@+id/timelineLineNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Time (right-aligned) -->
    <TextView
        android:id="@+id/timelineTimeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingEnd="4dp"
        android:textColor="@color/nav_gray"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
