<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="4dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <ImageView
        android:id="@+id/routePointIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_origin_dot"
        android:scaleType="centerInside"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/routePointLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:textColor="@color/nav_fg"
        android:textSize="15sp"
        android:maxLines="1"
        android:ellipsize="end" />

    <ImageButton
        android:id="@+id/routePointRemove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_close"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Remove point"
        android:scaleType="centerInside"
        android:padding="8dp"
        app:tint="@color/nav_gray" />

    <ImageView
        android:id="@+id/routePointDragHandle"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_drag_handle"
        app:tint="@color/nav_gray"
        android:scaleType="centerInside"
        android:importantForAccessibility="no" />
</LinearLayout>
